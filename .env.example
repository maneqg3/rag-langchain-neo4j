# Neo4j — sobe local via `npm run infra:up`
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=troque-esta-senha
NEO4J_INDEX_NAME=vector_index
NEO4J_NODE_LABEL=Chunk

# OpenRouter (LLM) — crie uma key gratuita em https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Veja modelos gratuitos atualizados em https://openrouter.ai/models?q=free
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Embeddings locais (Transformers.js)
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2

# Pipeline
DATA_PATH=./data/source.pdf
OUTPUTS_DIR=./outputs
TOP_K=4
SCORE_THRESHOLD=0.5
