{
  "name": "rag-langchain-neo4j",
  "version": "0.1.0",
  "description": "Pipeline RAG com LangChain JS, Neo4j e OpenRouter — projeto de portfólio.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "tsx src/index.ts",
    "eval": "tsx src/evalRunner.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "infra:up": "docker compose --env-file .env -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "generate:placeholder-pdf": "node scripts/generate-placeholder-pdf.mjs",
    "inspect:chunks": "node scripts/inspect-chunks.mjs"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@langchain/classic": "^1.0.38",
    "@langchain/community": "^1.1.29",
    "@langchain/core": "^1.2.1",
    "@langchain/neo4j": "^0.1.10",
    "@langchain/openai": "^1.5.3",
    "@langchain/textsplitters": "^1.0.1",
    "neo4j-driver": "^6.2.0",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "pdf-lib": "^1.17.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
